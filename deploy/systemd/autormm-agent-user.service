# autormm agent — systemd *user* service for GRAPHICAL Linux desktops.
# Runs inside your login session so it can capture the screen (X11) and inject
# input via XTEST.
#
# Install:
#   cp to ~/.config/systemd/user/
#   loginctl enable-linger $USER          # so it runs without an active TTY
#   systemctl --user enable --now autormm-agent-user
[Unit]
Description=autormm agent (desktop session)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
EnvironmentFile=%h/.config/autormm/agent.env
# Adjust if your display/auth differ (Xwayland/X11 only; native Wayland capture
# is not supported).
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority
ExecStart=%h/.local/bin/autormm-agent
Restart=always
RestartSec=5

[Install]
WantedBy=graphical-session.target
