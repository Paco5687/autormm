# Copy to /etc/autormm/agent.env (system service) or
# ~/.config/autormm/agent.env (user service) and fill in.

# Hub URL. Use TLS via a reverse proxy or -tls-cert in production.
AUTORMM_SERVER=http://HUB-IP:8765

# Must match the server's AUTORMM_ENROLL_TOKEN.
AUTORMM_ENROLL_TOKEN=CHANGE_ME_enroll

# Optional: stable id (defaults to the hostname) and free-form tags.
# AUTORMM_AGENT_ID=workshop-pc
# AUTORMM_TAGS=desktop,windows

# Set to 1 only if the hub uses a self-signed certificate.
# AUTORMM_INSECURE=1
