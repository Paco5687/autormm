# Copy to ~/.config/autormm/server.env and fill in strong random tokens.
# Generate tokens with, e.g.:  openssl rand -base64 24

# Bearer token that clients (autormm-client) and the dashboard must present.
AUTORMM_ADMIN_TOKEN=CHANGE_ME_admin

# Shared secret every agent presents when it registers.
AUTORMM_ENROLL_TOKEN=CHANGE_ME_enroll

# Optional. If unset, session-ticket signing derives a stable key from the two
# tokens above. Set explicitly if you want tickets to survive a token rotation.
# AUTORMM_SECRET=CHANGE_ME_secret

# Optional built-in TLS (leave empty when terminating TLS at Traefik).
# AUTORMM_TLS_CERT=/path/fullchain.pem
# AUTORMM_TLS_KEY=/path/privkey.pem
